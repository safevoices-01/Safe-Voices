{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", ".next/**", "build/**", "coverage/**"],
            "env": [
                "DATABASE_URL",
                "DIRECT_URL",
                "VERCEL",
                "VERCEL_ENV",
                "NODE_ENV",
                "SAFEVOICES_SECRET_PEPPER",
                "AI_GATEWAY_API_KEY",
                "GOOGLE_GENERATIVE_AI_API_KEY"
            ]
        },

        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": ["^lint"],
            "outputs": []
        },
        "typecheck": {
            "dependsOn": ["^typecheck"],
            "outputs": []
        },
        "test": {
            "dependsOn": ["^test"],
            "outputs": ["coverage/**"]
        },
        "clean": {
            "cache": false
        }
    }
}
